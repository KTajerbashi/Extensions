@page "/logger-advanced"
@using LoggerApp.Exceptions
@rendermode InteractiveServer

<div class="card shadow-sm">
    <div class="card-header text-center bg-dark text-white">Logs From Database</div>
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0 text-nowrap">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                <tr>
                    <th>Id</th>
                    <th>Level</th>
                    <th>TimeStamp</th>
                    <th>Message</th>
                    <th>Exception</th>
                    <th>SourceContext</th>
                    <th>CorrelationId</th>
                    <th>RequestPath</th>
                    <th>RequestMethod</th>
                    <th>StatusCode</th>
                    <th>Elapsed</th>
                    <th>Username</th>
                    <th>ClientIp</th>
                    <th>MachineName</th>
                    <th>Environment</th>
                    <th>Application</th>
                    <th>ThreadId</th>
                    <th>ProcessId</th>
                </tr>
            </thead>
            <tbody>
                @* در اینجا می‌توانید داده‌های خود را با یک foreach نمایش دهید *@
            </tbody>
        </table>
    </div>

    <div class="card-footer text-center">
        <button class="btn btn-danger mx-1" @onclick="throwDomainException">DomainException</button>
        <button class="btn btn-danger mx-1" @onclick="throwAppException">AppException</button>
        <button class="btn btn-danger mx-1" @onclick="throwDataBaseException">DataBaseException</button>
        <button class="btn btn-danger mx-1" @onclick="throwApiException">ApiException</button>
    </div>
</div>

@code {
    // نکته: در Blazor Server برای دکمه‌ها از @onclick استفاده کنید نه onclick (که مخصوص JS است)
    void throwDomainException() => throw new DomainException("DomainException: Business rule violated.");
    void throwAppException() => throw new AppException("AppException: Application processing failed.");
    void throwDataBaseException() => throw new DataBaseException("DataBaseException: Database operation failed.");
    void throwApiException() => throw new ApiException("ApiException: External API call failed.");
}
